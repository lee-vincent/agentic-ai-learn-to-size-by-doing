# Copy to terraform.tfvars (gitignored is NOT currently set for tfvars --
# only secrets.tfvars/*.secret.tfvars are ignored, so don't put anything
# sensitive in here) and adjust as needed. Every value below is also a
# perfectly reasonable default on its own -- this file exists to make the
# knobs discoverable, not because you must set them.

aws_region = "us-east-1"
project    = "gpu-sizing-lab"

# --- GPU compute ---
# Single g6e.2xlarge (1x L40S, 44.7 GiB VRAM, 8 vCPU, 64 GiB RAM). Verified
# live 2026-07-16 (us-east-1): $2.24208/hr on-demand. Qwen3.6-27B fits its
# VRAM at FP8 (~29 GiB weights) with ~15 GiB left for KV cache -- see
# infra/README.md. There is no node-count knob -- this design only ever
# creates one instance.
gpu_instance_type = "g6e.2xlarge"

# Leave empty to rely on SSM Session Manager (default). Only set this if you
# specifically need direct SSH into the instance.
ssh_ingress_cidrs = []
# ssh_ingress_cidrs = ["203.0.113.4/32"]

# --- Storage ---
# Model weights live directly on the root EBS volume (gp3, encrypted) --
# no FSx, no S3 staging bucket. 300 GiB comfortably holds the OS, the vLLM
# container image, and the Qwen3.6-27B FP8 checkpoint (~29 GiB) with room to
# spare. Bump if you also want to keep the INT4/AWQ checkpoint cached
# alongside FP8.
root_volume_size_gb = 300
